class Solution {
    public int longestOnes(int[] nums, int k) {
        int zero = 0;
        int len = 0;
        int i = 0;
        for(int j = 0; j < nums.length; j++){
            if(nums[j] == 0){
                zero++;
            }
            while(zero > k){
                if(nums[i] == 0){
                    zero--;
                }
                i++;
            }
            len = Math.max(len, j-i+1);
        }
        return len;
    }
}
