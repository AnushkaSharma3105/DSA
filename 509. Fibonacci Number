class Solution {
    public int fib(int n) {

        // using dynamic programming

        int prev1 = 1;
        int prev2 = 0;
        int result = 0;
        
        if(n <= 1){
            return n;
        }

        for(int i = 2; i <= n; i++){
            result = prev1 + prev2;
            prev2 = prev1;
            prev1 = result;
        }
        return result;

        // using recursion
        
        // if(n <= 1){
        //     return n;
        // }
        // else{
        //     return fib(n-1) + fib(n-2);
        // }
    }
}
