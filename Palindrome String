class Solution {
    boolean isPalindrome(String s) {
        // code here
        char[] arr = s.toCharArray();
        int n = arr.length;
        char r[] = new char[n];
        int idx = 0;
        for(int i = n-1; i >= 0; i--){
            r[idx] = arr[i];
            idx++;
        }
        
        if(Arrays.equals(arr,r)) return true;
        else return false;
    }
}
