class Solution {
    public int[] nextGreaterElement(int[] nums1, int[] nums2) {
        int n = nums1.length;
        int[] ans = new int[n];
        for(int i = 0; i < n; i++){
            for(int j = 0; j < nums2.length; j++){
                if(nums2[j] == nums1[i]){
                   int next = -1;

                    for(int k = j + 1; k < nums2.length; k++){
                        if(nums2[k] > nums2[j]){
                            next = nums2[k];
                            break;
                        }
                    }

                    ans[i] = next;
                    break;
                }
            }
        }
        return ans;
    }
}
