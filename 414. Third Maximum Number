class Solution {
    public int thirdMax(int[] nums) {
        int n = nums.length;
        Integer max = null;
        Integer max2 = null;
        Integer max3 = null;

        for(int num : nums){

            // skip duplicates
            if((max != null && num == max) || (max2 != null && num == max2) || (max3 != null && num == max3)){
                continue;
            }

            if(max == null || num > max){
                max3 = max2;
                max2 = max;
                max = num;
            }
            else if(max2 == null || num > max2){
                max3 = max2;
                max2 = num;
            }
            else if(max3 == null || num > max3){
                max3 = num;
            }
        }

        return (max3 == null) ? max : max3;

    }
}
