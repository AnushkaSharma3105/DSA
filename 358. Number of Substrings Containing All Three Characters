class Solution {
    public int numberOfSubstrings(String s) {
        // Brute force

        // int n = s.length();
        // int count = 0;
        // for(int i = 0; i < n; i++){
        //     HashSet<Character> set = new HashSet<>();
        //     for(int j = i; j < n; j++){
        //         set.add(s.charAt(j));
        //         if(set.contains('a') && set.contains('b') && set.contains('c')){
        //         count++;
        //         }
        //     }
        // }
        // return count;

        // Optimised way

        int i = 0, j = 0, n = s.length(), count = 0;
        int[] ans = new int[3];
        while(j < n){
            // putting element
            ans[s.charAt(j) - 'a']++; // character is converted into ascii value and then it is subtracted
            while(ans[0] >= 1 && ans[1] >=1 && ans[2] >= 1){
                count += n - j;
                ans[s.charAt(i) - 'a']--;
                i++;
            }
            j++;
        }
        return count;
    }
}
