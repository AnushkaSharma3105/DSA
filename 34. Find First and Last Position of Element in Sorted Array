class Solution {
    public int[] searchRange(int[] nums, int target) {
        int n = nums.length;
        int[] ans = new int[2];

        if(nums.length == 1){
            if(target == nums[0]){
                ans[0] = 0;
                ans[1] = 0;
                return ans;
            }
        }

        for(int i = 0; i < n; i++){
            if(nums[i] == target){
                ans[0] = i;
                int j = i;
                while(j < n && nums[j] == target){
                    ans[1] = j;
                    j++;
                }
                return ans;
            }
            
        }

        ans[0] = -1;
        ans[1] = -1;
        return ans;
    }
}
