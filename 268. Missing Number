        //     boolean found = false;
        //     for(int num : nums){
        //         if(num == i){
        //             found = true;
        //             break;
        //         }
        //     }
        //     if(!found){
        //         return i;
        //     }
        // }

        // return -1;


        int n = nums.length;
        HashSet<Integer> set = new HashSet<>();
        for(int i = 0; i < n; i++){
            set.add(nums[i]);
        }

        for(int i = 0; i <= n; i++){
            if(!set.contains(i)){
                return i;
            }
        }

        return -1;
    }
}
